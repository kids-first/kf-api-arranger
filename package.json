{
  "name": "kf-api-arranger",
  "version": "2.0.0",
  "description": "GraphQL API over Elasticsearch for the Kids First and INCLUDE portals — post-arranger rewrite (Apollo Server 5, in-tree SQON).",
  "type": "module",
  "main": "dist/src/index.js",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node ./dist/src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "rm -rf ./dist/* && tsc --build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "serve": "npm run build && npm start"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kids-first/kf-api-arranger.git"
  },
  "keywords": [
    "elasticsearch",
    "graphql",
    "apollo",
    "kids-first",
    "include"
  ],
  "author": "",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/kids-first/kf-api-arranger/issues"
  },
  "homepage": "https://github.com/kids-first/kf-api-arranger#readme",
  "dependencies": {
    "@apollo/server": "^5.0.0",
    "@as-integrations/express5": "^1.1.2",
    "@aws-sdk/client-s3": "^3.1054.0",
    "@aws-sdk/s3-request-presigner": "^3.1054.0",
    "@elastic/elasticsearch": "7.13.0",
    "@graphql-tools/schema": "^10.0.33",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "graphql": "^16.9.0",
    "graphql-fields": "^2.0.3",
    "graphql-type-json": "^0.3.2",
    "keycloak-connect": "^26.0.5",
    "node-cache": "^5.1.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-serve-static-core": "^5.0.1",
    "@types/node": "^24.0.0",
    "@types/supertest": "^7.2.0",
    "jsonwebtoken": "^9.0.3",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^3.2.4"
  }
}
