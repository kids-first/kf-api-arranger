{
  "name": "kf-api-arranger",
  "version": "1.0.0",
  "description": ":factory: a data-model aware GraphQL API that sits above an Elasticsearch cluster",
  "type": "module",
  "main": "dist/src/index.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node ./dist/src/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:silent": "jest --silent",
    "cleanAndBuild": "rm -rf ./dist/* && tsc --build",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "cbs": "npm run cleanAndBuild && npm start",
    "admin-project": "node admin/run.mjs",
    "post-re-alias-helper": "node admin/postReleaseIndicesToAliasesHelper.mjs",
    "delete-clinical-indices-helper": "node admin/deleteClinicalIndicesFromRelease.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kids-first/kf-api-arranger.git"
  },
  "keywords": [
    "arranger"
  ],
  "author": "",
  "license": "Apache-2.0",
  "licenses": [
    {
      "type": "Apache-2.0",
      "url": "http://www.apache.org/licenses/LICENSE-2.0"
    }
  ],
  "bugs": {
    "url": "https://github.com/kids-first/kf-api-arranger/issues"
  },
  "homepage": "https://github.com/kids-first/kf-api-arranger#readme",
  "dependencies": {
    "@apollo/server": "^5.0.0",
    "@arranger/middleware": "^2.19.4",
    "@as-integrations/express4": "^1.1.2",
    "@aws-sdk/client-s3": "^3.689.0",
    "@aws-sdk/s3-request-presigner": "^3.689.0",
    "@elastic/elasticsearch": "7.13.0",
    "@graphql-tools/schema": "^10.0.33",
    "ajv": "^8.17.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "filesize": "^3.6.1",
    "graphql": "^16.9.0",
    "graphql-fields": "^2.0.3",
    "graphql-parse-resolve-info": "^4.13.0",
    "graphql-type-json": "^0.3.2",
    "http-status-codes": "^2.3.0",
    "keycloak-connect": "^26.0.5",
    "lodash": "^4.17.21",
    "node-cache": "^5.1.2",
    "node-fetch": "^2.6.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-serve-static-core": "^5.0.1",
    "@types/jest": "^29.5.0",
    "@types/lodash": "^4.14.171",
    "@types/node": "^22.0.0",
    "@types/supertest": "^2.0.11",
    "@typescript-eslint/eslint-plugin": "^4.28.3",
    "@typescript-eslint/parser": "^4.28.3",
    "eslint": "^7.29.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-prettier": "^3.4.0",
    "eslint-plugin-simple-import-sort": "^7.0.0",
    "jest": "^29.7.0",
    "json-diff": "^1.0.6",
    "jsonwebtoken": "^8.5.1",
    "prettier": "^1.19.1",
    "supertest": "^6.1.2",
    "ts-jest": "^29.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
