{
    "name": "kf-api-arranger-v2",
    "version": "0.0.1",
    "private": true,
    "description": "Slice-S replacement for @arranger/server: Apollo 4 + TS + ES",
    "type": "module",
    "engines": {
        "node": ">=22"
    },
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "typecheck": "tsc --noEmit",
        "es:bootstrap": "tsx scripts/bootstrap-index.ts",
        "es:load": "tsx scripts/load-samples.ts"
    },
    "dependencies": {
        "@apollo/server": "^5.0.0",
        "@arranger/middleware": "^2.19.4",
        "@elastic/elasticsearch": "^7.17.14",
        "@graphql-tools/schema": "^10.0.33",
        "graphql": "^16.9.0",
        "graphql-type-json": "^0.3.2"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "tsx": "^4.19.0",
        "typescript": "^5.5.0"
    }
}
