{
    "compilerOptions": {
        "target": "ES2022",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "sourceMap": true,
        "outDir": "dist",
        "skipLibCheck": true,
        "strict": false,
        "noImplicitAny": false,
        "allowSyntheticDefaultImports": true,
        "lib": ["ES2022"],
        "types": ["vitest/globals"]
    },
    "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.test-utils.ts"],
    "include": [
        "src/**/*"
    ]
}
